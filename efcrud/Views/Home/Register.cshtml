
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Register</title>
    <link href="~/bootstrap/css/bootstrap.css" rel="stylesheet" />
    <script src="~/bootstrap/js/bootstrap.js"></script>
</head>
<body>
    <div class="d-flex justify-content-center align-items-center">
        <div class="bg-light h-50 w-50 border-black border d-flex justify-content-center flex-column ">
            <h1 class=" min-vh-10 bg-primary text-center"> Form Registration</h1><hr />
            <form action="/Home/Register" method="post" class="text-center">
                <input type="text" placeholder="enter your name " name="Name" /><br /><br />
                <input type="number" placeholder="enter your age " name="Age" /><br /><br />
                <input type="email" placeholder="example@gmail.com" name="Email" /><br /><br />
                <input type="text" placeholder="enter your mobile no." name="MobNo" /><br /><br />
                <input type="submit" value="submit" class="bg-success rounded-2" /><br />
            </form>
            <div class="text-center bg-warning m-2">
                @ViewBag.message
            </div>

            <a href="/Home/ManageStudent" class="text-center"> DISPLAYING DATA </a>

        </div>
    </div>
</body>
</html>
